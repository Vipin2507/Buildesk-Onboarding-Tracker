# SQLite database (file path relative to project root, or absolute)
DATABASE_URL=file:./data/buildesk.db

# Or set a directory (VPS): DATA_DIR=/var/lib/buildesk
# DATA_DIR=

# Cookie session signing secret (change in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Set to true ONLY when the site is served over HTTPS (certbot).
# Leave unset/false for http://IP access — Secure cookies will not stick on HTTP.
# COOKIE_SECURE=true

# Node
NODE_ENV=development

# Client portal links copied in Ticket Tracking (full URL prefix).
# Use your VPS IP or domain — clients open this to create tickets.
# Example: http://200.97.166.244  or  https://track.buildesk.com
VITE_PORTAL_BASE_URL=http://200.97.166.244
